{
  "name": "devcontainer/${localWorkspaceFolderBasename}",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "runArgs": [
    "--env-file", ".env"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "gerane.theme-dark-dracula",
        "ms-python.black-formatter",
        "srmeyers.git-prefix",
        "eamodio.gitlens",
        "ms-toolsai.jupyter",
        "pkief.material-icon-theme",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },

  // Install dependencies automatically after container creation
  "postCreateCommand": "pip3 install --user -r requirements.txt",

  // Use 'forwardPorts' to make container ports (like Flask/FastAPI) available locally
  "forwardPorts": [8000],

  // Connect as a non-root user for better security
  "remoteUser": "vscode"
}